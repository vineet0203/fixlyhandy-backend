SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost:5174,localhost:5175
APP_NAME=FixlyHandy
APP_ENV=local
APP_KEY=generate_with_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://localhost:5174,http://localhost:5173,http://127.0.0.1:5173

FRONTEND_URL=http://localhost:5173
FRONTEND_PASSWORD_RESET_URL=your_frontend_password_reset_url
EMPLOYEE_FRONTEND_URL=http://localhost:5174
CUSTOMER_FRONTEND_URL=http://localhost:5175
PASSWORD_RESET_TOKEN_EXPIRE=your_password_reset_token_expire

LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=trackjobs
DB_USERNAME=trackjobs
DB_PASSWORD=your_db_password

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379


MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=trackjobsofficial@gmail.com
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=trackjobsofficial@gmail.com
MAIL_FROM_NAME="FixlyHandy"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=1
PUSHER_APP_KEY=generate_with_php_artisan_key_generate
PUSHER_APP_SECRET=your_pusher_app_secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1
WEBSOCKETS_ENABLED_STATISTICS=false

# Notification Settings
NOTIFICATION_TRIES=3
NOTIFICATION_TIMEOUT=30
NOTIFICATION_BACKOFF_1=10
NOTIFICATION_BACKOFF_2=30
NOTIFICATION_BACKOFF_3=60

NOTIFICATION_EMAIL_QUEUE=emails
NOTIFICATION_DB_QUEUE=notifications

NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_DELAY=0
NOTIFICATION_EMAIL_RETRY=true
NOTIFICATION_EMAIL_MAX_RETRIES=3

# System Logger Settings
SYSTEM_LOGGER_EMAIL_ENABLED=false
SYSTEM_LOGGER_EMAIL_THROTTLE=5
SYSTEM_LOGGER_INCLUDE_TRACE=true
SYSTEM_LOGGER_DB_ENABLED=true
SYSTEM_LOGGER_DB_BATCH_SIZE=100

SEND_WELCOME_EMAIL=false
SEND_ADMIN_REGISTRATION_NOTIFICATION=false
ADMIN_NOTIFICATION_DELAY=0
WELCOME_EMAIL_DELAY=0

# Audit Log Configuration
AUDIT_LOG_ENABLED=true
AUDIT_BATCH_SIZE=100
AUDIT_RETENTION_DAYS=30
AUDIT_LOG_QUEUE=null

# Support and Admin Emails
MAIL_ADMIN_EMAIL=admin@localhost

# Use sync queue for local development
QUEUE_CONNECTION=sync

# Default system user ID for automated actions
SYSTEM_USER_ID=1

# IP Geolocation - disabled for localhost
IPINFO_TOKEN=
GEOLOCATION_CACHE_TTL=86400
GEOLOCATION_ENABLED=false
IPINFO_ENABLED=false
FREEIPAPI_ENABLED=false
IPAPI_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY=generate_with_php_artisan_key_generate
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

JWT_SECRET=your_jwt_secret
JWT_TTL=43200
JWT_REFRESH_TTL=43200

# Deployment Features - disabled for localhost
ENABLE_DEPLOYMENT_BACKUPS=false
ENABLE_AUTO_ROLLBACK=false
DEPLOYMENT_NOTIFICATION_EMAIL=
DEPLOYMENT_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Telegram - disabled for localhost
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI Features
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
